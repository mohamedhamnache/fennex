# Database
DATABASE_URL=postgresql://fennex:fennex@localhost:5432/fennex
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption (for API keys at rest)
ENCRYPTION_KEY=change-me-32-bytes-base64-encoded==

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-in-production

# Optional: Storage (S3-compatible)
# S3_BUCKET=fennex-assets
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=

# Optional: Email
# SENDGRID_API_KEY=
# FROM_EMAIL=noreply@fennex.ai

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...
# Frontend-visible Stripe price IDs (used by the billing settings tab)
NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_STARTER_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_ANNUAL=price_...

# AI Image Services
# Replicate — image-conditioned generation (Product tab, flux-kontext-pro)
# Get token at: replicate.com → Account → API tokens
# REPLICATE_API_KEY=r8_...

# Remove.bg — background removal (AI editing tools)
# Get key at: remove.bg/api
# REMOVE_BG_API_KEY=...

# Google OAuth (for Search Console integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set the authorized redirect URI to: http://localhost:8000/api/v1/analytics/gsc/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/analytics/gsc/callback
# FRONTEND_URL=http://localhost:3001
